# ====================================================================
# UTTECAM API - Template de Variables de Entorno
# ====================================================================
# 
# 📋 INSTRUCCIONES:
# 1. Copiar este archivo como .env (desarrollo) o configurar en producción
# 2. Reemplazar TODOS los valores de ejemplo con valores reales
# 3. NUNCA subir archivos .env con valores reales al repositorio
# 4. Usar valores fuertes y únicos para cada entorno
#
# ====================================================================

# ====================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ====================================================================

# Puerto de la aplicación (3000 por defecto)
PORT=3000

# Entorno: development | production | staging
NODE_ENV=development

# URL base de la API (importante para CORS y redirecciones)
# Desarrollo: http://localhost:3000
# Producción: https://api.uttecam.edu.mx
API_BASE_URL=http://localhost:3000

# Dominio principal (usado para cookies y CORS)
DOMAIN=localhost

# ====================================================================
# BASE DE DATOS - MYSQL/MARIADB
# ====================================================================

# Host de la base de datos
# Desarrollo: 127.0.0.1 o localhost
# Producción: IP o hostname del servidor MySQL
DB_HOST=127.0.0.1

# Puerto MySQL (3306 por defecto)
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=uttecam

# Usuario de la base de datos
# ⚠️ PRODUCCIÓN: Usar usuario con permisos mínimos necesarios
DB_USER=uttecam_user

# Contraseña de la base de datos
# ⚠️ PRODUCCIÓN: Usar contraseña fuerte (min 16 caracteres, alfanumérica + símbolos)
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Dialecto de la base de datos
DB_DIALECT=mysql

# ====================================================================
# SEGURIDAD - JWT
# ====================================================================

# Clave secreta para firmar tokens JWT
# ⚠️ CRÍTICO: Generar con: openssl rand -base64 64
# Debe ser único por entorno y NUNCA compartirse
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# Expiración del token JWT (ejemplos: 1h, 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# Emisor del token (identificador de la aplicación)
JWT_ISSUER=uttecam-api

# Audiencia del token (quien puede usar el token)
JWT_AUDIENCE=uttecam-users

# ====================================================================
# CORS - ORÍGENES PERMITIDOS
# ====================================================================

# Lista de orígenes permitidos (separados por comas, sin espacios)
# Desarrollo: incluir localhost en varios puertos
# Producción: SOLO dominios de producción
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Orígenes permitidos para credenciales (más restrictivo)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ====================================================================
# RATE LIMITING
# ====================================================================

# Ventana de tiempo para rate limit (en minutos)
RATE_LIMIT_WINDOW_MS=15

# Máximo de requests por ventana por IP
RATE_LIMIT_MAX_REQUESTS=100

# Rate limit para endpoints de autenticación (más restrictivo)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=15

# ====================================================================
# UPLOADS - ARCHIVOS
# ====================================================================

# Directorio base para uploads
UPLOAD_DIR=./uploads

# Tamaño máximo de archivo en MB (por defecto)
MAX_FILE_SIZE_MB=10

# Tamaño máximo para Hero Slides en MB
HERO_SLIDE_MAX_FILE_SIZE_MB=200

# Tamaño máximo para documentos PDF en MB
PDF_MAX_FILE_SIZE_MB=50

# Tipos MIME permitidos (separados por comas)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ====================================================================
# EMAIL - NODEMAILER
# ====================================================================

# Servicio de email (gmail, outlook, smtp)
EMAIL_SERVICE=gmail

# Host SMTP (si no usas un servicio predefinido)
EMAIL_HOST=smtp.gmail.com

# Puerto SMTP (465 para SSL, 587 para TLS)
EMAIL_PORT=587

# Usar SSL/TLS
EMAIL_SECURE=false

# Usuario/Email del remitente
EMAIL_USER=noreply@uttecam.edu.mx

# Contraseña o App Password
# ⚠️ Gmail: usar App Password, no contraseña regular
EMAIL_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD

# Email por defecto para notificaciones
DEFAULT_EMAIL=serviciosescolares@uttecam.edu.mx

# Email del administrador
ADMIN_EMAIL=admin@uttecam.edu.mx

# ====================================================================
# LOGGING
# ====================================================================

# Nivel de logging: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Directorio de logs
LOG_DIR=./logs

# Días de retención de logs
LOG_RETENTION_DAYS=30

# Tamaño máximo de archivo de log antes de rotar
LOG_MAX_SIZE=20m

# Máximo de archivos de log a mantener
LOG_MAX_FILES=14d

# ====================================================================
# SESSION & COOKIES
# ====================================================================

# Secret para sesiones
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET

# Dominio para cookies (producción)
COOKIE_DOMAIN=.uttecam.edu.mx

# Secure cookies (true en producción con HTTPS)
COOKIE_SECURE=false

# SameSite para cookies (strict | lax | none)
COOKIE_SAMESITE=lax

# ====================================================================
# REDIS (OPCIONAL - para cache y sessions)
# ====================================================================

# Host de Redis
REDIS_HOST=127.0.0.1

# Puerto de Redis
REDIS_PORT=6379

# Password de Redis (dejar vacío si no tiene)
REDIS_PASSWORD=

# Database de Redis (0-15)
REDIS_DB=0

# ====================================================================
# MONITOREO Y SALUD
# ====================================================================

# Endpoint de health check
HEALTH_CHECK_PATH=/health

# Timeout para health check (segundos)
HEALTH_CHECK_TIMEOUT=5

# Habilitar métricas de Prometheus
ENABLE_METRICS=false

# ====================================================================
# BACKUP Y RECUPERACIÓN
# ====================================================================

# Directorio para backups
BACKUP_DIR=./backups

# Retención de backups (días)
BACKUP_RETENTION_DAYS=30

# Habilitar backup automático
AUTO_BACKUP_ENABLED=false

# Hora de backup automático (formato cron: 0 2 * * * = 2AM diario)
AUTO_BACKUP_SCHEDULE=0 2 * * *

# ====================================================================
# CARACTERÍSTICAS OPCIONALES
# ====================================================================

# Habilitar modo debug
DEBUG_MODE=false

# Habilitar Swagger/OpenAPI docs
ENABLE_API_DOCS=true

# Ruta para documentación API
API_DOCS_PATH=/api-docs

# Habilitar compresión gzip
ENABLE_COMPRESSION=true

# Habilitar trust proxy (necesario detrás de nginx/apache)
TRUST_PROXY=false

# ====================================================================
# DESARROLLO (solo para NODE_ENV=development)
# ====================================================================

# Puerto del frontend en desarrollo
DEV_FRONTEND_PORT=5173

# Habilitar auto-reload en desarrollo
DEV_AUTO_RELOAD=true

# Mostrar SQL queries en consola
DEV_LOG_SQL=false

# ====================================================================
# NOTAS DE SEGURIDAD
# ====================================================================
# 
# 🔒 PRODUCCIÓN - Checklist de seguridad:
# 
# ✅ JWT_SECRET: Generado con openssl rand -base64 64
# ✅ DB_PASSWORD: Mínimo 16 caracteres, complejidad alta
# ✅ SESSION_SECRET: Generado aleatoriamente
# ✅ CORS_ORIGIN: Solo dominios de producción
# ✅ NODE_ENV: Debe ser 'production'
# ✅ COOKIE_SECURE: true (requiere HTTPS)
# ✅ TRUST_PROXY: true si está detrás de reverse proxy
# ✅ LOG_LEVEL: 'warn' o 'error' (no 'debug')
# ✅ DEBUG_MODE: false
# ✅ EMAIL_PASSWORD: App Password, no contraseña real
#
# 🔐 Comandos útiles para generar secrets:
# 
# JWT Secret:     openssl rand -base64 64
# Session Secret: openssl rand -hex 32
# UUID:           uuidgen
# Password:       openssl rand -base64 32
#
# ====================================================================
