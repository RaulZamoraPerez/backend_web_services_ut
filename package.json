{
  "name": "uttecam-api",
  "version": "2.0.0-secure",
  "description": "API CRUD para UTTECAM con Sequelize ORM, TypeScript y Seguridad OWASP Top 10",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run clean && tsc",
    "build:scripts": "tsc -p tsconfig.json --outDir dist && echo 'Scripts built to dist/'",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "build:prod": "npm run build && node scripts/utils/create-production-package.js",
    "deploy:prepare": "npm run build:prod && npm run deploy:zip",
    "deploy:zip": "echo 'Crear ZIP manualmente con: dist/, package.production.json, .env.example'",
    "db:reset": "ts-node -e \"require('./src/config/syncDatabase').syncDatabase(true)\"",
    "db:seed": "ts-node -e \"require('./src/config/syncDatabase').seedDatabase()\"",
    "db:populate": "ts-node scripts/seed-complete.js",
    "seed:all": "ts-node scripts/seed-all.ts --dev",
    "seed:carreras": "ts-node scripts/seed-carreras-attached.ts",
    "seed:all:dev": "ts-node scripts/seed-all.ts --dev",
    "seed:all:prod": "node scripts/seed-all.js",
    "seed:nosotros": "ts-node scripts/seed-nosotros.ts",
    "seed:educacion-continua": "ts-node scripts/seed-educacion-continua.ts",
    "create:admin:dev": "ts-node scripts/auth/create-admin.ts",
    "create:admin": "node scripts/create-admin.js",
    "test:files": "node scripts/tests/test-files.js",
    "test:tokens": "node scripts/tests/test-token-security.js",
    "security:test": "echo 'Testing security endpoints...' && curl -s http://localhost:3002/health",
    "lint": "echo 'Linting not configured yet'",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:ci": "jest --ci --coverage --watchAll=false --forceExit",
    "test:diagnostic": "DIAGNOSTIC_BACKEND_URL=${DIAGNOSTIC_BACKEND_URL:-https://api.uttecam.edu.mx} npm test -- diagnostic-online.test.ts --runInBand",
    "test:diagnostic:full": "DIAGNOSTIC_BACKEND_URL=${DIAGNOSTIC_BACKEND_URL:-https://api.uttecam.edu.mx} npm test -- diagnostic-online-comprehensive.test.ts --runInBand",
    "test:diagnostic:all": "DIAGNOSTIC_BACKEND_URL=${DIAGNOSTIC_BACKEND_URL:-https://api.uttecam.edu.mx} npm test -- diagnostic-online --runInBand",
    "test:security": "DIAGNOSTIC_BACKEND_URL=${DIAGNOSTIC_BACKEND_URL:-https://api.uttecam.edu.mx} npm test -- security-audit.test.ts --runInBand",
    "generate:prod-seeds": "node scripts/seeds/tools/generateProdProgramDetails.js",
    "assets:copy": "npx ts-node scripts/utils/move_assets.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "api",
    "uttecam"
  ],
  "author": "Universidad Tecnológica de Tecamachalco",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.1.0",
    "express-slow-down": "^3.0.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.1",
    "nodemailer": "^7.0.10",
    "sequelize": "^6.37.7",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.25",
    "@types/supertest": "^6.0.3",
    "axios": "^1.12.2",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
